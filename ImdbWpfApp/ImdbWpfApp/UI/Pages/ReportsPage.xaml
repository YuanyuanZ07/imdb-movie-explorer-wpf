<Page x:Class="ImdbWpfApp.UI.Pages.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="ReportsPage"
      Background="#F9FAFB">

	<Grid Margin="30">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="20"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="20"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<StackPanel>
			<TextBlock Text="Reports"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#111827"/>
			<TextBlock Text="Load top-rated movie results from the database."
                       FontSize="15"
                       Foreground="#6B7280"
                       Margin="0,8,0,0"/>
		</StackPanel>

		<Border Grid.Row="2" Background="White" CornerRadius="12" Padding="20">
			<Button Content="Load Top Rated Movies"
                    Width="180"
                    Height="36"
                    Background="#7C3AED"
                    Foreground="White"
                    BorderBrush="Transparent"
                    Click="LoadTopRatedButton_Click"/>
		</Border>

		<Border Grid.Row="4" Background="White" CornerRadius="12" Padding="16">
			<DataGrid ItemsSource="{Binding TopRatedMovies}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowBackground="White"
                      AlternatingRowBackground="#F3F4F6">
				<DataGrid.Columns>
					<DataGridTextColumn Header="Title" Binding="{Binding PrimaryTitle}" Width="*"/>
					<DataGridTextColumn Header="Rating" Binding="{Binding AverageRating}" Width="120"/>
					<DataGridTextColumn Header="Votes" Binding="{Binding NumVotes}" Width="120"/>
				</DataGrid.Columns>
			</DataGrid>
		</Border>
	</Grid>
</Page>