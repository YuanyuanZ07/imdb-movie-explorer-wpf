<Page x:Class="ImdbWpfApp.UI.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="HomePage"
      Background="#F9FAFB">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{Binding WelcomeTitle}"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="#111827"/>
            <TextBlock Text="{Binding WelcomeMessage}"
                       FontSize="16"
                       Foreground="#4B5563"
                       Margin="0,10,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <UniformGrid Grid.Row="2" Columns="3" Margin="0,20,0,0">
            <Border Background="White" CornerRadius="12" Padding="20" Margin="10">
                <StackPanel>
                    <TextBlock Text="Movies" FontSize="22" FontWeight="SemiBold" Foreground="#111827"/>
                    <TextBlock Text="Browse and search movie and TV title records."
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               Foreground="#6B7280"/>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="12" Padding="20" Margin="10">
                <StackPanel>
                    <TextBlock Text="People" FontSize="22" FontWeight="SemiBold" Foreground="#111827"/>
                    <TextBlock Text="Explore actors, directors, writers, and other people."
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               Foreground="#6B7280"/>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="12" Padding="20" Margin="10">
                <StackPanel>
                    <TextBlock Text="Reports" FontSize="22" FontWeight="SemiBold" Foreground="#111827"/>
                    <TextBlock Text="View top-rated titles and quick report-style data."
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               Foreground="#6B7280"/>
                </StackPanel>
            </Border>
        </UniformGrid>
    </Grid>
</Page>